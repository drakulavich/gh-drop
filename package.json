{
  "name": "gh-drop",
  "version": "0.1.0",
  "description": "Drop images into GitHub issues & PRs from the CLI. A gh extension powered by Bun.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --minify --sourcemap --outfile dist/gh-drop",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.3.12"
  }
}
